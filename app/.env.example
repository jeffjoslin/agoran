# Agoran — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # Server-side only — NEVER expose to browser

# ─── Database (Prisma) ───────────────────────────────────────
# Prisma v7 requires a driver adapter — URLs configured in prisma.config.ts
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                    # Use sk_live_... in production only
STRIPE_WEBHOOK_SECRET=whsec_placeholder_will_be_set_in_production  # From Stripe Dashboard > Webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Cloudflare R2 ───────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=agoran-products
R2_PUBLIC_URL=                                   # Optional: for admin/analytics only

# ─── Resend (Email) ──────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@agoran.ai

# ─── Anthropic (LLM for landing page generation) ─────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://agoran.ai             # Use https://staging.agoran.ai for staging
ADMIN_EMAIL=admin@bizooku.com

# ─── Agent API ───────────────────────────────────────────────
AGENT_API_SECRET=your_secret_used_to_hash_api_keys  # Used internally to hash/validate API keys
